{
  "name": "ielts-nguyen-tuyen-lms",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm exec concurrently -- -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "docker:up": "node scripts/docker.mjs up",
    "docker:down": "node scripts/docker.mjs down",
    "docker:reset": "node scripts/docker.mjs reset",
    "docker:logs": "node scripts/docker.mjs logs",
    "docker:ps": "node scripts/docker.mjs ps",
    "docker:rebuild": "node scripts/docker.mjs rebuild",
    "docker:config": "node scripts/docker.mjs config",
    "build:web": "powershell -NoProfile -Command \"if (Test-Path 'apps/web/.next') { Remove-Item -Recurse -Force 'apps/web/.next' }\" && npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "lint:web": "npm --workspace apps/web run lint",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:seed": "node --env-file=.env prisma/seed.mjs",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.2",
    "prisma": "^6.6.0",
    "typescript": "^5.6.3"
  }
}
