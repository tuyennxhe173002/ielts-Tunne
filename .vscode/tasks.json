{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Prisma Migrate Deploy",
      "type": "shell",
      "command": "npx prisma migrate deploy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Prisma Seed",
      "type": "shell",
      "command": "npm run prisma:seed",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run API Dev",
      "type": "shell",
      "command": "npm run dev:api",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": ".*",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*nest start.*|.*start:dev.*",
          "endsPattern": ".*Nest application successfully started.*|.*Listening at.*|.*ready.*"
        }
      }
    },
    {
      "label": "Run Web Dev",
      "type": "shell",
      "command": "npm run dev:web",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": ".*",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*next dev.*|.*dev:web.*",
          "endsPattern": ".*Ready in.*|.*Local:.*127.0.0.1:3000.*|.*http://localhost:3000.*"
        }
      }
    },
    {
      "label": "Run Full Stack",
      "dependsOn": [
        "Run API Dev",
        "Run Web Dev"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Build API",
      "type": "shell",
      "command": "npm run build:api",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Web",
      "type": "shell",
      "command": "npm run build:web",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run API Tests",
      "type": "shell",
      "command": "npm --workspace apps/api run test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Web E2E",
      "type": "shell",
      "command": "npm run test:e2e",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
